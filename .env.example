PORT=5050
NODE_ENV=development

# Intentionally public portfolio details.
VITE_CONTACT_EMAIL=mendoza.marcangelo28@gmail.com
VITE_PHONE_NUMBER=+63 9602161734
VITE_LOCATION=Tanza, Cavite
VITE_API_BASE_URL=
VITE_CANONICAL_URL=http://localhost:5173

# Firebase web configuration is used only by the lazy-loaded admin login.
# These values identify the Firebase app but are not administrator credentials.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Server-only Firebase Admin credentials. Never prefix these with VITE_.
# Recommended on Render: paste the full downloaded service-account JSON as one secret value.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Split credentials remain supported as an alternative.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Comma-separated Firebase Authentication UIDs allowed to use /dashboard.
ADMIN_UIDS=

# Comma-separated public origins allowed to call the API.
ALLOWED_ORIGINS=http://localhost:5173
CANONICAL_SITE_URL=http://localhost:5173
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX=5
